# Copy to .env (`cp .env.example .env`) and fill in real values.
# Used by docker-compose.yml.

# ─────────── AWS (S3 for model + producer CSV source) ───────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=accident-severity-dev-data

# ─────────── RDS Postgres (dashboard reads aggregations) ───────────
DB_HOST=accident-severity-dev-pg.cctwww0wsavn.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=dashboard
DB_USER=dashboard_admin
DB_PASS=replace-with-real-rds-password

# ─────────── Event Hubs (Kafka surface) ───────────
KAFKA_BROKERS=accident-severity-dev-kafka-aqk7cm.servicebus.windows.net:9093
KAFKA_SASL_USERNAME=$ConnectionString
KAFKA_SASL_PASSWORD=Endpoint=sb://...

# ─────────── Producer tuning ───────────
PRODUCER_RATE=100
PRODUCER_MAX_RECORDS=0

# ─────────── ML predict service ───────────
MODEL_KEY=models/severity_classifier.joblib
MODEL_CACHE_TTL_SEC=300
